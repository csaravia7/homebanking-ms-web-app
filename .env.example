# Database Configuration
DATABASE_URL=postgresql://homebank:secure123@localhost:5432/homebanking_db
DB_HOST=postgres
DB_PORT=5432
DB_USER=homebank
DB_PASSWORD=secure123
DB_NAME=homebanking_db

# API Gateway
API_GATEWAY_PORT=8080
API_GATEWAY_HOST=0.0.0.0
LOG_LEVEL=info

# Auth Service
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_HOST=0.0.0.0
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY=24h

# Account Service
ACCOUNT_SERVICE_PORT=3003
ACCOUNT_SERVICE_HOST=0.0.0.0

# Transaction Service
TRANSACTION_SERVICE_PORT=3004
TRANSACTION_SERVICE_HOST=0.0.0.0

# Notification Service
NOTIFICATION_SERVICE_PORT=3005
NOTIFICATION_SERVICE_HOST=0.0.0.0

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SDK_DISABLED=false
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Jaeger (Legacy)
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# Service Names for Tracing
OTEL_SERVICE_NAME=homebanking

# Application Environment
NODE_ENV=development
ENVIRONMENT=development

# Nginx
NGINX_PORT=80
NGINX_SSL_PORT=443

# Redis (Optional - para caching)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Azure Configuration (Para AKS)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_KEY_VAULT_URL=
